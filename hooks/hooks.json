{
  "description": "claude-code-multisession hooks — auto-check lm-assist services on session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
